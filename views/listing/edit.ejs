<% layout("/layouts/boilerplate") %>
<body>
    

      <form method="post" action="/location/<%= listing._id %>?_method=put" novalidate class="needs-validation">
        <div class="mb-3">
             <label for="title" class="form-label">Titele </label>
            <input name="listing[title]" type="text" value="<%= listing.title %>" class="form-control" required>
          <!-- when we give something title then came up -->
            <div class="valid-feedback">titte looks good</div>
            
          <!-- when title is empty then come up -->
           <div class="invalid-feedback">please Enter title</div>
        </div>
        
        <div class="mb-3">
              <label for="title" class="form-label">Description </label>
            <input  name="listing[description]" value="<%= listing.description %>" class="form-control" required></input>

             <!-- when title is empty then come up -->
           <div class="invalid-feedback">please Enter Description</div>
        </div>
        
        <div class="mb-3">
             <label for="image" class="form-label">Image_url</label>
             <input name="listing[image]" type="text" value="<%= listing.image.url%>" class="form-control" required>
        </div>

<div class="row">

 <div class="mb-3 col-md-4" >
        <label for="price" class="form-label">Price</label>
         <input name="listing[price]" type="number" value="<%=listing.price %>" class="form-control" required>

          <!-- when title is empty then come up -->
           <div class="invalid-feedback">please Enter price</div>
       </div>


          <div class="mb-3 col-8" >
        <label for="location" class="form-label">Location</label>
         <input name="listing[location]" type="text" value="<%= listing.location %>" class="form-control" required>

          <!-- when title is empty then come up -->
           <div class="invalid-feedback">please Enter location</div>
       </div>

</div>

      
       
    
       
       <div class="mb-3" >
         <label for="country" class="form-label">Country</label>
        <input name="listing[country]" type="text" value="<%= listing.country %>" class="form-control" required>

         <!-- when title is empty then come up -->
           <div class="invalid-feedback">please Enter country</div>
       </div>
        
        <button class="btn btn-dark">Done! </button>
    </form>
</body>
