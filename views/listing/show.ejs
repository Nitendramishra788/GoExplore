<% layout("/layouts/boilerplate") %>

<div class="container my-5">

  <div class="row justify-content-center">
    <div class="col-lg-10">

      <!-- MAIN CARD -->
      <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <!-- IMAGE -->
        <img 
          src="<%= listing.image.url %>" 
          class="img-fluid"
          style="height: 420px; object-fit: cover;"
          alt="<%= listing.title %>"
        >

        <!-- BODY -->
        <div class="card-body p-4 p-md-5">

          <!-- TITLE -->
          <h2 class="fw-bold mb-3">
            <%= listing.title %>
          </h2>

          <!-- LOCATION -->
          <p class="text-muted mb-4">
            <i class="fa-solid fa-location-dot me-2"></i>
            <%= listing.location %>, <%= listing.country %>
          </p>

          <!-- DESCRIPTION -->
          <p class="fs-5 mb-4">
            <%= listing.description %>
          </p>

          <!-- PRICE -->
          <div class="d-flex align-items-center mb-4">
            <span class="badge bg-success fs-6 px-3 py-2">
              ₹ <%= listing.price %> / night
            </span>
          </div>

          <!-- ACTION BUTTONS (ONLY AUTHOR) -->
          <% if(currentUser && currentUser.role === "author"){ %>

          <div class="d-flex gap-3">
            <a href="/location/<%= listing._id %>/edit" class="btn btn-outline-primary px-4">
              Edit
            </a>

            <form action="/location/<%= listing._id %>?_method=DELETE" method="POST">
              <button class="btn btn-outline-danger px-4">
                Delete
              </button>
            </form>
          </div>

          <% } %>

        </div>
      </div>

    </div>
  </div>

<hr>

<!-- REVIEW SECTION -->
<div class="col-8 offset-3">

  <h4>Leave a Review</h4>

  <% if(currentUser){ %>

  <form action="/location/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">

    <div class="mb-3 mt-3">

      <label for="rating" class="form-label">Rating</label>

      <fieldset class="starability-slot">
        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked />
        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
        <label for="first-rate1">1 star</label>

        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
        <label for="first-rate2">2 stars</label>

        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
        <label for="first-rate3">3 stars</label>

        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
        <label for="first-rate4">4 stars</label>

        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
        <label for="first-rate5">5 stars</label>
      </fieldset>

    </div>

    <div class="mb-3 mt-3"> 
      <label for="comment" class="form-label">Comment</label>
      <textarea name="review[comment]" id="comment" class="form-control" required></textarea>
      <div class="invalid-feedback">please Enter something</div>
    </div>

    <button class="btn btn-outline-primary">Submit</button>
  </form>

  <% } %>

  <hr>

  <h4>All Reviews</h4>

  <div class="row">

    <% for(review of listing.reviews){ %>

      <div class="card col-lg-5 mt-3 mb-3">
        <div class="card-body">

          <h5 class="card-title">User</h5>

          <p class="starability-result" data-rating="<%= review.rating %>">
            Rated: <%= review.rating %> stars
          </p>

          <p class="card-text"><%= review.comment %></p>

          <% if(currentUser && currentUser.role === "author"){ %>

          <form action="/location/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
            <button class="btn btn-sm btn-outline-danger">Remove</button>
          </form>

          <% } %>

        </div>
      </div>

    <% } %>

  </div>

</div>

</div>